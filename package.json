{
  "name": "kumakuma-website-root",
  "version": "1.0.0",
  "description": "Root package to run both backend and frontend",
  "scripts": {
    "start": "concurrently \"npm run backend\" \"npm run frontend\"",
    "backend": "cd backend && npm run dev",
    "frontend": "cd frontend/kumakuma-website && npm run dev"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
