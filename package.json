{
  "name": "kumakuma-website",
  "version": "1.0.0",
  "description": "KumaKuma Website - Full Stack",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "predev": "npx kill-port 8000 || exit 0",
    "dev": "concurrently \"nodemon server.js\" \"cd client && npx vite\"",
    "build": "cd client && npm install && npm run build",
    "install:all": "npm install && cd client && npm install",
    "seed": "node seeds/seedData.js"
  },
  "dependencies": {
    "axios": "^1.16.1",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.10.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "midtrans-client": "^1.4.3",
    "mongoose": "^8.0.3",
    "multer": "^1.4.5-lts.1",
    "multer-storage-cloudinary": "^4.0.0",
    "pdfkit": "^0.19.1",
    "resend": "^6.12.4"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "nodemon": "^3.0.2"
  },
  "overrides": {
    "multer-storage-cloudinary": {
      "cloudinary": "$cloudinary"
    }
  }
}
