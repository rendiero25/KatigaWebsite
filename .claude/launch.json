{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Backend (Express)",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["nodemon", "server.js"],
      "port": 8000,
      "autoPort": false
    },
    {
      "name": "Frontend (Vite)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev", "--prefix", "client", "--", "--port", "5180", "--strictPort"],
      "port": 5180,
      "autoPort": false
    }
  ]
}
